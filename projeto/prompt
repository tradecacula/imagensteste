"use server";

import { revalidatePath } from "next/cache";
import { db } from "@/lib/db";
import { exigirComprador } from "@/lib/session";
import { texto, textoOuNull, parseDecimalBr, parseIntOrNull } from "@/lib/util";
import { lerCsv, numeroBr } from "@/lib/csv";

// ---------------------------------------------------------------------------
// Tipos de retorno padronizados (antes: void, sem feedback de erro na UI)
// ---------------------------------------------------------------------------
export interface ResultadoAcaoSku {
  sucesso: boolean;
  mensagem?: string;
}

export async function salvarSku(
  _prev: ResultadoAcaoSku,
  formData: FormData
): Promise<ResultadoAcaoSku> {
  await exigirComprador();
  const id = texto(formData.get("id"));

  const codigo = texto(formData.get("codigo")).trim();
  const descricao = texto(formData.get("descricao")).trim();

  if (!codigo || !descricao) {
    return { sucesso: false, mensagem: "Preencha os campos obrigatórios: código e descrição." };
  }

  const dados = {
    codigo,
    descricao,
    grupo: textoOuNull(formData.get("grupo")),
    categoria: textoOuNull(formData.get("categoria")),
    fabricante: textoOuNull(formData.get("fabricante")),
    codigoBarras: textoOuNull(formData.get("codigoBarras")),
    unidLarguraCm: parseDecimalBr(formData.get("unidLarguraCm")),
    unidAlturaCm: parseDecimalBr(formData.get("unidAlturaCm")),
    unidProfundidadeCm: parseDecimalBr(formData.get("unidProfundidadeCm")),
    // Antes ausentes aqui: só eram gravados via importação CSV.
    atacadoLarguraCm: parseDecimalBr(formData.get("atacadoLarguraCm")),
    atacadoAlturaCm: parseDecimalBr(formData.get("atacadoAlturaCm")),
    atacadoProfundidadeCm: parseDecimalBr(formData.get("atacadoProfundidadeCm")),
    unidadesPorAtacado: parseIntOrNull(formData.get("unidadesPorAtacado")),
  };

  try {
    if (id) {
      await db.sku.update({ where: { id }, data: dados });
    } else {
      await db.sku.upsert({
        where: { codigo: dados.codigo },
        update: dados,
        create: dados,
      });
    }
  } catch (e) {
    return {
      sucesso: false,
      mensagem: e instanceof Error ? `Erro ao salvar: ${e.message}` : "Erro desconhecido ao salvar o SKU.",
    };
  }

  revalidatePath("/cadastros/skus");
  return { sucesso: true };
}

export async function excluirSku(
  _prev: ResultadoAcaoSku,
  formData: FormData
): Promise<ResultadoAcaoSku> {
  await exigirComprador();
  const id = texto(formData.get("id"));
  if (!id) {
    return { sucesso: false, mensagem: "SKU inválido." };
  }

  const [emUso, comVendas] = await Promise.all([
    db.croquiItem.count({ where: { skuId: id } }),
    db.vendaMensal.count({ where: { skuId: id } }),
  ]);

  if (emUso > 0 || comVendas > 0) {
    return {
      sucesso: false,
      mensagem: `Não é possível excluir: usado em ${emUso} croqui(s) e ${comVendas} lançamento(s) de venda.`,
    };
  }

  try {
    await db.sku.delete({ where: { id } });
  } catch (e) {
    return {
      sucesso: false,
      mensagem: e instanceof Error ? `Erro ao excluir: ${e.message}` : "Erro desconhecido ao excluir o SKU.",
    };
  }

  revalidatePath("/cadastros/skus");
  return { sucesso: true };
}

export interface ResultadoImportacaoSku {
  ok: number;
  erros: { linha: number; motivo: string }[];
  totalErros: number;
  processado: boolean;
}

// Colunas reconhecidas (nomes normalizados): codigo, descricao, grupo,
// categoria, fabricante, codigo_barras, unid_largura_cm, unid_altura_cm,
// unid_profundidade_cm, atacado_largura_cm, atacado_altura_cm,
// atacado_profundidade_cm, unidades_por_atacado
export async function importarSkusCsv(
  _prev: ResultadoImportacaoSku,
  formData: FormData
): Promise<ResultadoImportacaoSku> {
  await exigirComprador();
  const arquivo = formData.get("arquivo");
  if (!(arquivo instanceof File) || arquivo.size === 0) {
    return {
      ok: 0,
      erros: [{ linha: 0, motivo: "Selecione um arquivo CSV." }],
      totalErros: 1,
      processado: true,
    };
  }

  const buffer = Buffer.from(await arquivo.arrayBuffer());
  const { cabecalho, linhas } = lerCsv(buffer);

  const col = (nome: string) => cabecalho.indexOf(nome);
  const iCodigo = col("codigo");
  const iDescricao = col("descricao");
  if (iCodigo < 0 || iDescricao < 0) {
    return {
      ok: 0,
      erros: [
        {
          linha: 1,
          motivo: `Cabeçalho precisa conter as colunas "codigo" e "descricao". Encontrado: ${cabecalho.join(", ")}`,
        },
      ],
      totalErros: 1,
      processado: true,
    };
  }

  const campo = (linha: string[], nome: string): string | undefined => {
    const i = col(nome);
    return i >= 0 ? linha[i] : undefined;
  };

  let ok = 0;
  const erros: { linha: number; motivo: string }[] = [];
  // Rastreia códigos já vistos no próprio arquivo para avisar sobre
  // duplicidade interna (o upsert faz a última ocorrência prevalecer).
  const codigosVistos = new Map<string, number>();

  for (let n = 0; n < linhas.length; n++) {
    const linha = linhas[n];
    const numLinha = n + 2; // 1-indexado + cabeçalho
    const codigo = (linha[iCodigo] ?? "").trim();
    const descricao = (linha[iDescricao] ?? "").trim();
    if (!codigo) {
      erros.push({ linha: numLinha, motivo: "Código vazio" });
      continue;
    }

    const primeiraOcorrencia = codigosVistos.get(codigo);
    if (primeiraOcorrencia) {
      erros.push({
        linha: numLinha,
        motivo: `Código duplicado neste arquivo (já apareceu na linha ${primeiraOcorrencia}); esta linha sobrescreveu a anterior.`,
      });
    }
    codigosVistos.set(codigo, numLinha);

    try {
      const dados = {
        descricao: descricao || codigo,
        grupo: campo(linha, "grupo") || null,
        categoria: campo(linha, "categoria") || null,
        fabricante: campo(linha, "fabricante") || null,
        codigoBarras: campo(linha, "codigo_barras") || null,
        unidLarguraCm: numeroBr(campo(linha, "unid_largura_cm")),
        unidAlturaCm: numeroBr(campo(linha, "unid_altura_cm")),
        unidProfundidadeCm: numeroBr(campo(linha, "unid_profundidade_cm")),
        atacadoLarguraCm: numeroBr(campo(linha, "atacado_largura_cm")),
        atacadoAlturaCm: numeroBr(campo(linha, "atacado_altura_cm")),
        atacadoProfundidadeCm: numeroBr(campo(linha, "atacado_profundidade_cm")),
        unidadesPorAtacado: (() => {
          const v = numeroBr(campo(linha, "unidades_por_atacado"));
          return v == null ? null : Math.round(v);
        })(),
      };
      await db.sku.upsert({
        where: { codigo },
        update: dados,
        create: { codigo, ...dados },
      });
      ok++;
    } catch (e) {
      erros.push({
        linha: numLinha,
        motivo: e instanceof Error ? e.message : "Erro desconhecido",
      });
    }
  }

  revalidatePath("/cadastros/skus");
  return { ok, erros: erros.slice(0, 50), totalErros: erros.length, processado: true };
}

